# Management Database (Central DB for tenants and users)
MANAGEMENT_DATABASE_URL="postgresql://user:password@localhost:5432/management_db"

# Tenant Database URL — used ONLY for prisma migrate deploy in the CLI script.
# At runtime, each tenant's connectionUrl is fetched from the management DB.
TENANT_DATABASE_URL="postgresql://user:password@localhost:5432/default_tenant_db"

# Superuser connection — used to CREATE DATABASE / CREATE USER per tenant
DATABASE_URL="postgresql://user:password@localhost:5432/management_db"

# Server
PORT=3000

# Podman socket path on the host (mounted into the container as /var/run/docker.sock)
DOCKER_HOST_PATH=/run/user/1000/podman/podman.sock
# DOCKER_HOST="unix:///var/run/docker.sock"
DOCKER_HOST="/run/user/1000/podman/podman.sock"

# Better Auth
BETTER_AUTH_SECRET="change-me-in-production-use-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# JWT (used by tenantGuard to verify Better Auth JWTs via JWKS)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

GEMINI_API_KEY=

WORKFLOW_RUN_DEBUG_THROW=1

NEXT_PUBLIC_GRAFANA_DASHBOARD_PATH="/d/flowforge-global-health/flowforge-global-health"